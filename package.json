{
  "name": "@open-crypto-broker/cryptobroker-client",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/lib/client.mjs",
      "require": "./dist/lib/client.cjs"
    }
  },
  "files": [
    "./dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "tsdown --build --clean",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "eslint --fix && prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "test": "jest --coverage",
    "prepare": "husky || true"
  },
  "keywords": [
    "cryptobroker",
    "crypto-broker",
    "crypto-broker-client",
    "apeiro",
    "apeirora",
    "crypto",
    "agility"
  ],
  "contributors": [
    "Arturo Guridi",
    "Miyana Stange"
  ],
  "bugs": {
    "url": "https://github.com/open-crypto-broker/crypto-broker-client-js.git"
  },
  "license": "Apache-2.0",
  "description": "Client Javascript repository to interact with a deployed Crypto Broker Server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-crypto-broker/crypto-broker-client-js.git"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@peculiar/x509": "^1.14.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "rxjs": "^7.8.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "bufbuild": "^0.2.0",
    "@bufbuild/protobuf": "^2.11.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "tsconfig": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.5",
    "tsdown": "^0.21.6",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
