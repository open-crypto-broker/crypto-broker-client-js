{
  "name": "@open-crypto-broker/cryptobroker-client",
  "version": "0.2.2",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/lib/client.mjs",
      "require": "./dist/lib/client.cjs"
    }
  },
  "files": [
    "./dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist/*",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "eslint --fix && prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "test": "jest --coverage",
    "prepare": "husky || true"
  },
  "keywords": [
    "cryptobroker",
    "crypto-broker",
    "crypto-broker-client",
    "apeiro",
    "apeirora",
    "crypto",
    "agility"
  ],
  "contributors": [
    "Arturo Guridi",
    "Miyana Stange"
  ],
  "bugs": {
    "url": "https://github.com/open-crypto-broker/crypto-broker-client-js.git"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "Apache-2.0",
  "description": "Client Javascript repository to interact with a deployed Crypto Broker Server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-crypto-broker/crypto-broker-client-js.git"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@peculiar/x509": "^1.14.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "rxjs": "^7.8.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bufbuild": "^0.2.0",
    "@bufbuild/protobuf": "^2.11.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "tsconfig": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.5",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  }
}
